/*
  Headers de seguridad para Cloudflare Pages
  Aplican a TODO el sitio. Para headers específicos de una ruta, agregá un
  bloque abajo con el path correspondiente.

  ‒ HSTS sin "preload" (preload requiere sumisión manual y es irreversible
    para años; mejor activarlo después de validar que TODO funciona en HTTPS).
  ‒ CSP permisiva pero suficiente: scripts solo desde self + CDNJs (Three.js
    si lo agregás), estilos self + Google Fonts + FontAwesome (con unsafe-inline
    porque FontAwesome inyecta estilos).
  ‒ Permissions-Policy cierra TODO por defecto (principio de menor privilegio).
*/

  Strict-Transport-Security: max-age=31536000; includeSubDomains
  X-Frame-Options: SAMEORIGIN
  X-Content-Type-Options: nosniff
  Referrer-Policy: same-origin
  Permissions-Policy: accelerometer=(), camera=(), geolocation=(), gyroscope=(), magnetometer=(), microphone=(), payment=(), usb=()
  Cross-Origin-Opener-Policy: same-origin
  Cross-Origin-Embedder-Policy: require-corp
  Content-Security-Policy: default-src 'self'; script-src 'self' https://cdnjs.cloudflare.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://cdnjs.cloudflare.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: hero-bg.jfif; connect-src 'self'; frame-ancestors 'none'; base-uri 'self'; form-action 'self'

/*.svg
  Content-Type: image/svg+xml

/*.jfif
  Content-Type: image/jpeg

/*.js
  Content-Type: application/javascript; charset=utf-8
