/*
  Headers de seguridad para Cloudflare Pages.
  Aplican a TODO el sitio.

  Cambios vs versión anterior:
  ‒ script-src ahora incluye unpkg.com (Lenis smooth scroll) y cdnjs.cloudflare.com.
  ‒ font-src incluye cdnjs.cloudflare.com (FontAwesome), nope, fonts.gstatic.com.
  ‒ img-src limpio: 'self' data: blob: (sin literales como 'hero-bg.jfif').
  ‒ COEP pasa de require-corp → credentialless (más laxo, permite iframes
    cross-origin sin pedir Cross-Origin-Resource-Policy).
  ‒ HSTS sin "preload" (irreversible).
*/

  Strict-Transport-Security: max-age=31536000; includeSubDomains
  X-Frame-Options: SAMEORIGIN
  X-Content-Type-Options: nosniff
  Referrer-Policy: same-origin
  Permissions-Policy: accelerometer=(), autoplay=(), camera=(), cross-origin-isolated=(), geolocation=(), gyroscope=(), magnetometer=(), microphone=(), payment=(), usb=()
  Cross-Origin-Opener-Policy: same-origin
  Cross-Origin-Embedder-Policy: credentialless
  Content-Security-Policy: default-src 'self'; script-src 'self' https://cdnjs.cloudflare.com https://unpkg.com https://*.unpkg.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://cdnjs.cloudflare.com; font-src 'self' https://fonts.gstatic.com https://cdnjs.cloudflare.com; img-src 'self' data: blob:; connect-src 'self'; frame-ancestors 'none'; base-uri 'self'; form-action 'self'

/*.svg
  Content-Type: image/svg+xml

/*.jfif
  Content-Type: image/jpeg

/*.js
  Content-Type: application/javascript; charset=utf-8
